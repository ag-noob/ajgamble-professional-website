---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="wrap">
		<a href="/" class="mark">AJ <em>Gamble</em></a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/experience">Experience</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a href="https://www.linkedin.com/in/ajgamble" target="_blank" rel="noopener" class="lk">LinkedIn</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		background: var(--bg);
		border-bottom: 1px solid var(--line);
	}
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 96px;
		height: 96px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.mark {
		font-family: 'Spectral', Georgia, serif;
		font-size: 25px;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: var(--paper);
		text-decoration: none;
	}
	.mark em {
		color: var(--brass);
		font-style: italic;
	}
	.links {
		display: flex;
		gap: 40px;
		align-items: center;
	}
	.links :global(a) {
		font-family: 'Archivo', sans-serif;
		font-size: 13px;
		letter-spacing: 0.06em;
		font-weight: 500;
		color: var(--soft);
		text-decoration: none;
	}
	.links :global(a.active) {
		color: var(--paper);
		font-weight: 500;
		text-decoration: none;
	}
	.lk {
		color: var(--bg) !important;
		background: var(--brass);
		padding: 10px 18px;
		border-radius: 2px;
		font-weight: 600 !important;
		transition: background-color 0.2s ease;
	}
	.lk:hover {
		background: var(--brass-hover);
	}
	@media (max-width: 720px) {
		.wrap {
			padding: 0 24px;
		}
		.links {
			gap: 20px;
		}
	}
</style>
