---
const today = new Date();
---

<footer>
	<div class="wrap">
		<div class="mark">AJ Gamble</div>
		<div class="links">
			<a id="contact-email" href="#" data-user="aj.gamble321" data-domain="gmail.com">Email Me</a>
			<a href="https://www.linkedin.com/in/ajgamble" target="_blank" rel="noopener">LinkedIn</a>
		</div>
		<span class="rights">&copy; {today.getFullYear()} &middot; All rights reserved</span>
	</div>
</footer>
<script>
	const link = document.getElementById('contact-email');
	if (link instanceof HTMLAnchorElement) {
		const user = link.dataset.user;
		const domain = link.dataset.domain;
		link.href = `mailto:${user}@${domain}`;
	}
</script>
<style>
	footer {
		border-top: 1px solid var(--line);
	}
	.wrap {
		max-width: 1280px;
		margin: 0 auto;
		padding: 0 96px;
		height: 108px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 12px;
	}
	.mark {
		font-family: 'Spectral', Georgia, serif;
		font-size: 18px;
		font-weight: 600;
		color: var(--paper);
	}
	.links {
		display: flex;
		gap: 30px;
	}
	.links a {
		font-family: 'Archivo', sans-serif;
		font-size: 13px;
		letter-spacing: 0.03em;
		color: var(--soft);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.links a:hover {
		color: var(--brass);
	}
	.rights {
		font-family: 'Archivo', sans-serif;
		font-size: 13px;
		color: var(--soft);
	}
	@media (max-width: 720px) {
		.wrap {
			padding: 16px 24px;
			height: auto;
			justify-content: center;
			text-align: center;
		}
	}
</style>
