---
const today = new Date();
---

<footer>
	<div class="contact">
		<a id="contact-email" href="#" data-user="aj.gamble321" data-domain="gmail.com">Email Me</a>
		<span class="divider">|</span>
		<a href="https://www.linkedin.com/in/ajgamble" target="_blank" rel="noopener">LinkedIn</a>
	</div>
	&copy; {today.getFullYear()} AJ Gamble. All rights reserved.
</footer>
<script>
	const link = document.getElementById('contact-email');
	if (link instanceof HTMLAnchorElement) {
		const user = link.dataset.user;
		const domain = link.dataset.domain;
		link.href = `mailto:${user}@${domain}`;
	}
</script>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.contact {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.75em;
		margin-bottom: 1em;
	}
	.contact a {
		text-decoration: none;
		color: var(--accent);
		font-weight: 600;
	}
	.contact a:hover {
		text-decoration: underline;
	}
	.divider {
		color: rgb(var(--gray));
	}
</style>
