---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = {
	title: string;
	description: string;
	heroImage?: string;
};

const { title, description, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 1280px;
				margin: 0 auto;
				padding: 48px 96px 0;
				aspect-ratio: 4 / 3;
				overflow: hidden;
				display: flex;
				justify-content: center;
				align-items: center;
				box-sizing: border-box;
			}
			.hero-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				display: block;
				margin: 0 auto;
				border-radius: 3px;
				border: 1px solid var(--line);
			}
			.prose {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--paper);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.title hr {
				max-width: 200px;
				margin: 0 auto;
				border-top: 1px solid var(--line);
			}
			@media (max-width: 720px) {
				.hero-image {
					padding: 24px 24px 0;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
